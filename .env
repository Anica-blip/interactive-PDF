# Cloudflare R2 Storage Configuration
# These should be set in Cloudflare Pages environment variables
R2_PUBLIC_URL=https://files.3c-public-library.org
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=3c-library-files

# Supabase Configuration
SUPABASE_URL=https://cgxjqsbrditbteqhdyus.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Cloudflare Stream Configuration
CLOUDFLARE_STREAM_TOKEN=your_stream_api_token
CLOUDFLARE_STREAM_SUBDOMAIN=your_stream_subdomain

# Node Environment
NODE_ENV=development
ENVIRONMENT=Production
