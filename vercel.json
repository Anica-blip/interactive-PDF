{
  "version": 2,
  "redirects": [
    {
      "source": "/pdfs/:path*",
      "destination": "https://files.3c-public-library.org/pdfs/:path*",
      "permanent": true,
      "statusCode": 301
    },
    {
      "source": "/thumbnails/:path*",
      "destination": "https://files.3c-public-library.org/thumbnails/:path*",
      "permanent": true,
      "statusCode": 301
    },
    {
      "source": "/media/:path*",
      "destination": "https://files.3c-public-library.org/media/:path*",
      "permanent": true,
      "statusCode": 301
    },
    {
      "source": "/interactive-pdfs/:path*",
      "destination": "https://files.3c-public-library.org/interactive-pdfs/:path*",
      "permanent": true,
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "destination": "https://files.3c-public-library.org/:path*",
      "permanent": true,
      "statusCode": 301
    }
  ]
}
